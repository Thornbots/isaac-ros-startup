# /etc/thornbots/launch.env
# Thornbots Isaac ROS runtime configuration.
# Adjust these values before enabling the systemd service.
# After changes: sudo systemctl daemon-reload && sudo systemctl restart thornbots

# ── Host workspace ─────────────────────────────────────────────────────────
# This is the directory mounted into the container at /workspaces/isaac_ros-dev.
# Must be the same path you use when running run_dev.sh interactively.
ISAAC_ROS_WS_HOST=/home/your_user/workspaces/isaac_ros-dev

# ── Snapshot output ─────────────────────────────────────────────────────────
# Host-side directory for realsense captures. Created automatically on start.
SNAPSHOT_OUTPUT_HOST=/data/realsense-captures

# ── Model ───────────────────────────────────────────────────────────────────
# Path to the TensorRT engine file *relative to ISAAC_ROS_WS_HOST*.
# Full container path will be /workspaces/isaac_ros-dev/<MODEL_REL_PATH>
MODEL_REL_PATH=isaac_ros_assets/models/yolo11/yolo11s_fp16.plan

# ── Inference thresholds ────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.25
NMS_THRESHOLD=0.45
CENTER_SAMPLE_FRACTION=0.25

# ── DJI serial bridge ───────────────────────────────────────────────────────
SERIAL_DEVICE=/dev/ttyTHS1
SERIAL_BAUDRATE=115200

# ── Snapshot capture ────────────────────────────────────────────────────────
# Set to True to enable training data capture on launch.
ENABLE_SNAPSHOT=False

# ── Docker image ────────────────────────────────────────────────────────────
# Name of the built Isaac ROS image. run_dev.sh builds this as isaac_ros_dev-aarch64.
# Only change this if you explicitly retag the image.
THORNBOTS_IMAGE=isaac_ros_dev-aarch64

# ── Container user ──────────────────────────────────────────────────────────
# UID/GID that workspace-entrypoint.sh creates the 'admin' user as.
# Use the UID of whoever owns the host workspace files (id -u / id -g).
HOST_USER_UID=1000
HOST_USER_GID=1000
