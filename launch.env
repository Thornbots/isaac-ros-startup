# /etc/thornbots/launch.env
# Thornbots Isaac ROS runtime configuration.
#
# Most per-machine values (workspace path, UID, GID) are auto-detected at
# startup if left blank.  Override any field here to pin it explicitly.
#
# After changes: sudo systemctl daemon-reload && sudo systemctl restart thornbots

# ── Host workspace ─────────────────────────────────────────────────────────
# Host path mounted into the container at /workspaces/isaac_ros-dev.
# Leave blank to auto-discover (scans ~/workspaces/isaac_ros-dev for every
# user, then falls back to parsing ISAAC_ROS_WS from shell config files).
ISAAC_ROS_WS_HOST=

# ── Snapshot output ─────────────────────────────────────────────────────────
# Host-side directory for realsense captures. Created automatically on start.
SNAPSHOT_OUTPUT_HOST=/data/realsense-captures

# ── Model ───────────────────────────────────────────────────────────────────
# Path to the TensorRT engine file *relative to ISAAC_ROS_WS_HOST*.
# Full container path will be /workspaces/isaac_ros-dev/<MODEL_REL_PATH>
MODEL_REL_PATH=isaac_ros_assets/models/yolo11/yolo11s_fp16.plan

# ── Inference thresholds ────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.5
NMS_THRESHOLD=0.45
CENTER_SAMPLE_FRACTION=0.25

# ── Target prioritisation (detection picker) ────────────────────────────────
# The picker scores each surviving detection as:
#   confidence + CENTER_WEIGHT*centrality + PRIORITY_CLASS_BONUS (if priority class)
# and sends the highest-scoring one to the gimbal.
#   CENTER_WEIGHT        weight of centrality (1 at image centre, 0 at corners) —
#                        higher values favour whatever the robot is already aimed at.
#   PRIORITY_CLASS_BONUS score added when the class is a high-value target.
#   PRIORITY_CLASS_IDS   high-value class IDs (no spaces). [2,6] = the 3rd target
#                        in each 0-3 / 4-7 team group.
CENTER_WEIGHT=1.0
PRIORITY_CLASS_BONUS=0.5
PRIORITY_CLASS_IDS=[2,6]

# ── DJI serial bridge ───────────────────────────────────────────────────────
SERIAL_DEVICE=/dev/ttyTHS1
SERIAL_BAUDRATE=115200

# ── Navigation / SLAM (sentry_pkg) ──────────────────────────────────────────
# Launch the sentry_pkg navigation + SLAM stack (auto.launch.py) alongside the
# vision pipeline. Set to False to run the vision pipeline only.
ENABLE_SENTRY_PKG=True
# Serial device for the SLLIDAR. The USB lidar hotplugs, so it is NOT pinned
# with --device; inside the container it is read through the /dev:/host-dev
# bind mount. Use /host-dev/ttyUSB0 here (NOT /dev/ttyUSB0, which inside the
# container is the CDI-managed device tree without the USB lidar node).
LIDAR_SERIAL_DEVICE=/host-dev/ttyUSB0
# Launch rviz2 inside the nav stack. Off by default — the robot runs headless
# (no display in the service context). Set True only for bench debugging.
ENABLE_RVIZ=False

# ── Snapshot capture ────────────────────────────────────────────────────────
# Set to True to enable training data capture on launch.
ENABLE_SNAPSHOT=False

# ── Docker image ────────────────────────────────────────────────────────────
# Name of the built Isaac ROS image. run_dev.sh builds this as isaac_ros_dev-aarch64.
# Only change this if you explicitly retag the image.
THORNBOTS_IMAGE=isaac_ros_dev-aarch64

# ── Container user ──────────────────────────────────────────────────────────
# UID/GID that workspace-entrypoint.sh creates the 'admin' user as.
# Leave blank to auto-detect from the owner of ISAAC_ROS_WS_HOST.
HOST_USER_UID=
HOST_USER_GID=

# ── Persistent logging ──────────────────────────────────────────────────────
# Directory where timestamped per-run log files are written.
# Each run creates thornbots-YYYYMMDD-HHMMSS.log; old files are pruned
# automatically to LOG_KEEP_COUNT (default: 20).
# Leave blank for the default (/var/log/thornbots).
# Set to e.g. /home/nano-sentry/logs to keep logs in your home directory.
LOG_DIR=
LOG_KEEP_COUNT=20
